<!doctype html><html lang="<%= locale %>"><%- include('../partials/head') %><body><%- include('../partials/header') %>
<main class="container auth-wrap"><section class="card auth-card"><h1><%= t('auth.loginTitle') %></h1><form id="loginForm" class="stack">
<label><%= t('auth.username') %><input name="username" required /></label>
<label><%= t('auth.password') %><input name="password" type="password" required /></label>
<button class="btn" type="submit"><%= t('auth.submitLogin') %></button><p id="authError" class="error"></p></form></section></main>
<%- include('../partials/footer') %><%- include('../partials/scripts') %></body></html>

<!doctype html><html lang="<%= locale %>"><%- include('../partials/head') %><body><%- include('../partials/header') %>
<main class="container auth-wrap"><section class="card auth-card"><h1><%= t('auth.registerTitle') %></h1><form id="registerForm" class="stack">
<label><%= t('auth.username') %><input name="username" required /></label>
<label><%= t('auth.password') %><input name="password" type="password" required /></label>
<label>Language<select name="language"><option value="ru">ru</option><option value="en">en</option></select></label>
<button class="btn" type="submit"><%= t('auth.submitRegister') %></button><p id="authError" class="error"></p></form></section></main>
<%- include('../partials/footer') %><%- include('../partials/scripts') %></body></html>
